<config>

  <ImportLibrary library="gmGraphics"/>

  <SdlWindow
      size="640 480"
      title="ChromaKey"
      GLMajor="3" GLMinor="3">

    <SdlContext
        DEF="SDLContext"
        useVideo="1"/>

    <PosedPlanarView
        fieldOfView="1 -1">

      <Viewpoint/>

      <TextureRenderer>
        <ImageTexture
            file="urn:gramods:gmGraphics/resources/gray_fur_texture.png"/>
      </TextureRenderer>

      <TextureRenderer>
        <ChromaKeyTexture
            key="0 1 0"
            tolerance="0.4 0.5">
          <YuvDecodeTexture>
            <UvcTexture
                DEF="CAM"
                resolution="640 480"
                framerate="20"
                format="YUYV"
                decode="false"/>
          </YuvDecodeTexture>
        </ChromaKeyTexture>
      </TextureRenderer>

    </PosedPlanarView>
  </SdlWindow>

</config>
